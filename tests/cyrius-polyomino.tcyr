# cyrius-polyomino test suite — deterministic, headless (no tty / framebuffer).
# stdlib auto-included via cyrius.cyml [deps]; project modules below.

include "src/piece.cyr"
include "src/board.cyr"
include "src/score.cyr"
include "src/gravity.cyr"
include "src/rng.cyr"
include "src/srs.cyr"
include "src/world.cyr"
include "src/framebuf.cyr"
include "src/render.cyr"
include "src/hud.cyr"
include "src/input.cyr"
include "src/das.cyr"

# --- helpers -----------------------------------------------------------

fn t_fill_row_full(b, r): i64 {
    var c = 0;
    while (c < board_w(b)) {
        board_set(b, c, r, 1);
        c = c + 1;
    }
    return 0;
}

fn t_fill_row_except(b, r, gap1, gap2): i64 {
    var c = 0;
    while (c < board_w(b)) {
        if (c != gap1) {
            if (c != gap2) { board_set(b, c, r, 1); }
        }
        c = c + 1;
    }
    return 0;
}

# Force the active piece to a known state (bypasses the RNG) so move /
# rotate / gravity are deterministically testable.
fn t_force(wd, t, rot, x, y): i64 {
    store64(wd + WO_CUR_TYPE, t);
    store64(wd + WO_CUR_ROT, rot);
    store64(wd + WO_CUR_X, x);
    store64(wd + WO_CUR_Y, y);
    store64(wd + WO_STATE, WS_PLAYING);
    return 0;
}

# --- piece -------------------------------------------------------------

fn test_piece() {
    test_group("piece");
    assert_eq(piece_count(), 7, "seven tetrominoes");
    assert_eq(pk(0, 0), 0, "pk(0,0)");
    assert_eq(pk(3, 1), 49, "pk(3,1) = 0x31");
    var w = word4(1, 2, 3, 4);
    assert_eq(w & 255, 1, "word4 byte0");
    assert_eq((w >> 8) & 255, 2, "word4 byte1");
    assert_eq((w >> 24) & 255, 4, "word4 byte3");

    # I, spawn (rot 0): cells (0,1)(1,1)(2,1)(3,1)
    var iw = piece_word(0, 0);
    assert_eq(cell_x(iw, 0), 0, "I0 cell0 x");
    assert_eq(cell_y(iw, 0), 1, "I0 cell0 y");
    assert_eq(cell_x(iw, 3), 3, "I0 cell3 x");
    assert_eq(cell_y(iw, 3), 1, "I0 cell3 y");

    # O is rotation-invariant
    assert_eq(piece_word(1, 0), piece_word(1, 1), "O rot0 == rot1");
    assert_eq(piece_word(1, 0), piece_word(1, 2), "O rot0 == rot2");
    assert_eq(piece_word(1, 0), piece_word(1, 3), "O rot0 == rot3");
    var ow = piece_word(1, 0);
    assert_eq(cell_x(ow, 0), 1, "O cell0 x");
    assert_eq(cell_y(ow, 0), 0, "O cell0 y");
    assert_eq(cell_x(ow, 3), 2, "O cell3 x");
    assert_eq(cell_y(ow, 3), 1, "O cell3 y");

    # T, spawn (rot 0): cells (1,0)(0,1)(1,1)(2,1)
    var tw = piece_word(2, 0);
    assert_eq(cell_x(tw, 0), 1, "T0 cell0 x");
    assert_eq(cell_y(tw, 0), 0, "T0 cell0 y");
    assert_eq(cell_x(tw, 2), 1, "T0 cell2 x");
    assert_eq(cell_y(tw, 2), 1, "T0 cell2 y");

    # Every (type, rotation) has four cells with coords in 0..3.
    var t = 0;
    var r = 0;
    var k = 0;
    var pw = 0;
    var ok = 1;
    while (t < 7) {
        r = 0;
        while (r < 4) {
            pw = piece_word(t, r);
            k = 0;
            while (k < 4) {
                if (cell_x(pw, k) > 3) { ok = 0; }
                if (cell_y(pw, k) > 3) { ok = 0; }
                k = k + 1;
            }
            r = r + 1;
        }
        t = t + 1;
    }
    assert_eq(ok, 1, "all cells within the 4x4 box");
    return 0;
}

# --- board -------------------------------------------------------------

fn test_board() {
    test_group("board");
    var b = board_new(10, 20);
    assert_eq(board_w(b), 10, "width 10");
    assert_eq(board_h(b), 20, "height 20");
    assert_eq(board_count(b), 0, "fresh board empty");

    board_set(b, 3, 5, 4);
    assert_eq(board_at(b, 3, 5), 4, "set/get cell");
    assert_eq(board_count(b), 1, "one cell occupied");
    board_set(b, 3, 5, 0);
    assert_eq(board_count(b), 0, "cleared cell");

    # collisions against an empty board
    assert_eq(board_collides(b, piece_word(1, 0), 0, 0), 0, "O at origin free");
    assert_eq(board_collides(b, piece_word(1, 0), 8, 0), 1, "O off right edge");
    assert_eq(board_collides(b, piece_word(1, 0), 0, 18), 0, "O resting on floor row");
    assert_eq(board_collides(b, piece_word(1, 0), 0, 19), 1, "O through the floor");

    # collision against an occupied cell
    board_set(b, 1, 0, 1);
    assert_eq(board_collides(b, piece_word(1, 0), 0, 0), 1, "O hits an occupied cell");
    board_set(b, 1, 0, 0);

    # lock writes type+1 into the four cells
    board_lock(b, 1, 0, 0, 0);
    assert_eq(board_at(b, 1, 0), 2, "lock O -> value 2");
    assert_eq(board_at(b, 2, 1), 2, "lock O cell 3");
    assert_eq(board_count(b), 4, "O locked four cells");

    # single line clear with a survivor above
    var b2 = board_new(10, 20);
    t_fill_row_full(b2, 19);
    board_set(b2, 5, 18, 1);
    assert_eq(board_row_full(b2, 19), 1, "row 19 full");
    assert_eq(board_row_full(b2, 18), 0, "row 18 not full");
    assert_eq(board_clear_lines(b2), 1, "one line cleared");
    assert_eq(board_count(b2), 1, "survivor remains");
    assert_eq(board_at(b2, 5, 19), 1, "survivor fell to row 19");
    assert_eq(board_row_full(b2, 19), 0, "row 19 no longer full");

    # double line clear
    var b3 = board_new(10, 20);
    t_fill_row_full(b3, 18);
    t_fill_row_full(b3, 19);
    board_set(b3, 0, 17, 1);
    assert_eq(board_clear_lines(b3), 2, "two lines cleared");
    assert_eq(board_count(b3), 1, "one survivor");
    assert_eq(board_at(b3, 0, 19), 1, "survivor dropped two rows");

    # no clear on a non-full board
    var b4 = board_new(10, 20);
    board_set(b4, 0, 19, 1);
    assert_eq(board_clear_lines(b4), 0, "nothing to clear");
    assert_eq(board_count(b4), 1, "board unchanged");
    return 0;
}

# --- rng ---------------------------------------------------------------

fn test_rng() {
    test_group("rng");
    assert_eq(rng_next_state(123), rng_next_state(123), "LCG deterministic");
    var s = 1;
    var i = 0;
    var p = 0;
    var ok = 1;
    while (i < 64) {
        s = rng_next_state(s);
        p = rng_pick7(s);
        if (p < 0) { ok = 0; }
        if (p > 6) { ok = 0; }
        i = i + 1;
    }
    assert_eq(ok, 1, "pick7 always in 0..6");

    # 7-bag: a freshly filled bag is a permutation of 0..6 (each piece once)
    var bag[7];
    rng_fill_bag(12345, &bag);
    var seen = 0;
    i = 0;
    while (i < 7) {
        seen = seen | (1 << load8(&bag + i));
        i = i + 1;
    }
    assert_eq(seen, 127, "7-bag contains each of the seven pieces once");
    assert_eq(rng_fill_bag(999, &bag), rng_fill_bag(999, &bag), "bag fill is deterministic for a seed");

    # same seed -> same opening pieces
    var ba = board_new(10, 20);
    var wa = world_new(ba, 777);
    var bb = board_new(10, 20);
    var wb = world_new(bb, 777);
    assert_eq(world_cur_type(wa), world_cur_type(wb), "same seed -> same first piece");
    assert_eq(world_next(wa), world_next(wb), "same seed -> same next piece");

    # the upcoming queue is also a 7-bag stream: across the first 14 draws
    # (two bags), each piece appears exactly twice — no floods, no droughts.
    var bc = board_new(10, 20);
    var wc = world_new(bc, 55);
    var counts[7];
    i = 0;
    while (i < 7) { store8(&counts + i, 0); i = i + 1; }
    # the active piece is the first draw; count it plus the next 13 draws
    store8(&counts + world_cur_type(wc), 1);
    var d = 0;
    var pt = 0;
    while (d < 13) {
        pt = world_draw_next(wc);
        store8(&counts + pt, load8(&counts + pt) + 1);
        d = d + 1;
    }
    var two_each = 1;
    i = 0;
    while (i < 7) {
        if (load8(&counts + i) != 2) { two_each = 0; }
        i = i + 1;
    }
    assert_eq(two_each, 1, "14 draws = two full bags, each piece twice");
    return 0;
}

# --- world -------------------------------------------------------------

fn test_world_new() {
    test_group("world new");
    var b = board_new(10, 20);
    var wd = world_new(b, 42);
    assert_eq(world_state(wd), WS_PLAYING, "starts playing");
    assert_eq(world_score(wd), 0, "score 0");
    assert_eq(world_lines(wd), 0, "lines 0");
    assert_eq(world_level(wd), 0, "level 0");
    assert_eq(world_cur_x(wd), SPAWN_X, "spawn x");
    assert_eq(world_cur_y(wd), SPAWN_Y, "spawn y");
    assert_eq(world_cur_rot(wd), 0, "spawn rotation 0");
    var ct = world_cur_type(wd);
    assert_eq(ct >= 0, 1, "cur type >= 0");
    assert_eq(ct < 7, 1, "cur type < 7");
    return 0;
}

fn test_world_move() {
    test_group("world move");
    var b = board_new(10, 20);
    var wd = world_new(b, 42);
    t_force(wd, 1, 0, 3, 2);                 # O at col 3
    assert_eq(world_move(wd, 1), 1, "move right ok");
    assert_eq(world_cur_x(wd), 4, "x = 4");
    assert_eq(world_move(wd, 0 - 1), 1, "move left ok");
    assert_eq(world_move(wd, 0 - 1), 1, "move left ok 2");
    assert_eq(world_cur_x(wd), 2, "x = 2");

    # right wall: O cells are cols ox+1, ox+2; max origin is 7
    t_force(wd, 1, 0, 6, 2);
    assert_eq(world_move(wd, 1), 1, "to x = 7 ok");
    assert_eq(world_move(wd, 1), 0, "x = 8 blocked at right wall");
    assert_eq(world_cur_x(wd), 7, "stays at 7");

    # left wall: O leftmost cell is ox+1, so origin -1 is still on-board
    t_force(wd, 1, 0, 0, 2);
    assert_eq(world_move(wd, 0 - 1), 1, "to x = -1 ok (box overhang)");
    assert_eq(world_move(wd, 0 - 1), 0, "x = -2 blocked at left wall");
    assert_eq(world_cur_x(wd), 0 - 1, "stays at -1");
    return 0;
}

fn test_world_rotate() {
    test_group("world rotate");
    var b = board_new(10, 20);
    var wd = world_new(b, 42);
    t_force(wd, 2, 0, 3, 4);                 # T with room
    assert_eq(world_rotate(wd, 1), 1, "rotate CW ok");
    assert_eq(world_cur_rot(wd), 1, "rot = 1");
    world_rotate(wd, 1);
    world_rotate(wd, 1);
    assert_eq(world_cur_rot(wd), 3, "rot = 3");
    world_rotate(wd, 1);
    assert_eq(world_cur_rot(wd), 0, "wraps to 0");
    assert_eq(world_rotate(wd, 0 - 1), 1, "rotate CCW ok");
    assert_eq(world_cur_rot(wd), 3, "CCW wraps to 3");

    # SRS floor kick: rotating T at the floor lifts it up instead of failing
    t_force(wd, 2, 0, 3, 18);                # T resting at the bottom
    assert_eq(world_rotate(wd, 1), 1, "rotation near the floor kicks up");
    assert_eq(world_cur_rot(wd), 1, "rotated to state 1");
    assert_eq(world_cur_x(wd), 2, "floor kick shifted x by -1");
    assert_eq(world_cur_y(wd), 17, "floor kick lifted y by -1");
    return 0;
}

# --- SRS wall kicks ----------------------------------------------------

fn test_srs() {
    test_group("srs");
    # offset pack/unpack round-trips across the signed -2..2 range
    assert_eq(srs_dx(srs_off(0, 0), 0), 0, "off(0,0) dx");
    assert_eq(srs_dy(srs_off(0, 0), 0), 0, "off(0,0) dy");
    assert_eq(srs_dx(srs_off(2, (0 - 2)) << 8, 1), 2, "off(2,-2) dx in byte 1");
    assert_eq(srs_dy(srs_off(2, (0 - 2)) << 8, 1), 0 - 2, "off(2,-2) dy in byte 1");
    assert_eq(srs_dx(srs_off((0 - 1), 1) << 16, 2), 0 - 1, "off(-1,1) dx in byte 2");

    # transition ids cover the eight adjacent rotations
    assert_eq(srs_trans(0, 1), 0, "0>1");
    assert_eq(srs_trans(1, 0), 1, "1>0");
    assert_eq(srs_trans(2, 3), 4, "2>3");
    assert_eq(srs_trans(0, 3), 7, "0>3");

    # test 0 is the no-kick attempt for every transition, both tables
    var tr = 0;
    var ok = 1;
    while (tr < 8) {
        if (srs_dx(srs_word_jlstz(tr), 0) != 0) { ok = 0; }
        if (srs_dy(srs_word_jlstz(tr), 0) != 0) { ok = 0; }
        if (srs_dx(srs_word_i(tr), 0) != 0) { ok = 0; }
        if (srs_dy(srs_word_i(tr), 0) != 0) { ok = 0; }
        tr = tr + 1;
    }
    assert_eq(ok, 1, "test 0 is (0,0) for all transitions");

    # open-space rotation takes test 0 — origin unchanged
    var b = board_new(10, 20);
    var wd = world_new(b, 42);
    t_force(wd, 2, 0, 4, 8);
    assert_eq(world_rotate(wd, 1), 1, "open rotate ok");
    assert_eq(world_cur_x(wd), 4, "no kick in open space (x)");
    assert_eq(world_cur_y(wd), 8, "no kick in open space (y)");

    # I left-wall kick: vertical I flush to the left wall, rotate CCW to
    # horizontal. Test 0 fails (cells off the wall); I-table test 1 (dx +2)
    # pulls it onto the board.
    var b2 = board_new(10, 20);
    var w2 = world_new(b2, 42);
    t_force(w2, 0, 1, 0 - 2, 6);             # I rot1 column at board col 0
    assert_eq(world_rotate(w2, 0 - 1), 1, "I rotates off the left wall via a kick");
    assert_eq(world_cur_rot(w2), 0, "I rotated to horizontal");
    assert_eq(world_cur_x(w2), 0, "left wall kick shifted x by +2");

    # fully blocked: fill the board, carve out only T's current cells, so
    # every rotation + kick collides and the rotation fails.
    var b3 = board_new(10, 20);
    var rr = 0;
    var cc = 0;
    while (rr < 20) {
        cc = 0;
        while (cc < 10) { board_set(b3, cc, rr, 1); cc = cc + 1; }
        rr = rr + 1;
    }
    var w3 = world_new(b3, 42);
    t_force(w3, 2, 0, 3, 4);                 # T rot0 cells (4,4)(3,5)(4,5)(5,5)
    board_set(b3, 4, 4, 0);
    board_set(b3, 3, 5, 0);
    board_set(b3, 4, 5, 0);
    board_set(b3, 5, 5, 0);
    assert_eq(world_rotate(w3, 1), 0, "rotation fully boxed in fails");
    assert_eq(world_cur_rot(w3), 0, "rotation unchanged when every kick blocked");
    return 0;
}

fn test_world_gravity() {
    test_group("world gravity");
    var b = board_new(10, 20);
    var wd = world_new(b, 42);
    t_force(wd, 1, 0, 3, 0);
    assert_eq(world_gravity(wd), 0, "gravity drops, no clear");
    assert_eq(world_cur_y(wd), 1, "y = 1 after gravity");

    # drop to the floor and lock; a fresh piece spawns
    t_force(wd, 1, 0, 3, 18);                # O resting on the floor row
    assert_eq(world_gravity(wd), 0, "lock, no lines cleared");
    assert_eq(board_count(world_board(wd)), 4, "four cells locked");
    assert_eq(world_cur_y(wd), SPAWN_Y, "new piece spawned at top");
    return 0;
}

fn test_world_clear() {
    test_group("world clear");
    # Two rows full except cols 4,5 — an O dropped there completes both.
    var b = board_new(10, 20);
    t_fill_row_except(b, 18, 4, 5);
    t_fill_row_except(b, 19, 4, 5);
    var wd = world_new(b, 42);
    t_force(wd, 1, 0, 3, 18);                # O fills cols 4,5 rows 18,19
    assert_eq(world_gravity(wd), 2, "two lines cleared on lock");
    assert_eq(world_lines(wd), 2, "lines counter = 2");
    assert_eq(world_score(wd), 300, "double = 300 at level 0");
    assert_eq(board_count(world_board(wd)), 0, "board emptied");
    assert_eq(world_level(wd), 0, "still level 0");
    return 0;
}

fn test_world_topout() {
    test_group("world topout");
    var b = board_new(10, 20);
    t_fill_row_full(b, 0);
    t_fill_row_full(b, 1);
    var wd = world_new(b, 42);               # spawn into the full top -> over
    assert_eq(world_state(wd), WS_GAME_OVER, "top-out on spawn into a full top");
    # a stepped game also reaches game over via repeated locking
    var b2 = board_new(10, 20);
    var w2 = world_new(b2, 99);
    var i = 0;
    while (i < 2000) {
        world_gravity(w2);
        if (world_state(w2) == WS_GAME_OVER) { i = 2000; }
        i = i + 1;
    }
    assert_eq(world_state(w2), WS_GAME_OVER, "straight-drop stacking tops out");
    return 0;
}

# --- hard drop ---------------------------------------------------------

fn test_world_harddrop() {
    test_group("world harddrop");
    var b = board_new(10, 20);
    var wd = world_new(b, 42);
    t_force(wd, 1, 0, 3, 0);                  # O at the top, empty column
    assert_eq(world_hard_drop(wd), 0, "hard drop locks, no lines cleared");
    assert_eq(board_count(world_board(wd)), 4, "piece locked on hard drop");
    # O fell from y=0 to y=18 (18 cells) -> 18 * 2 = 36 points
    assert_eq(world_score(wd), 36, "hard drop scores two points per cell");
    assert_eq(board_at(world_board(wd), 4, 19), 2, "O landed on the floor row");

    # hard drop that completes a line clears it
    var b2 = board_new(10, 20);
    t_fill_row_except(b2, 19, 4, 5);
    var w2 = world_new(b2, 42);
    t_force(w2, 1, 0, 3, 0);                  # O drops into cols 4,5
    assert_eq(world_hard_drop(w2), 1, "hard drop into a gap clears the line");
    assert_eq(world_lines(w2), 1, "line counted");
    return 0;
}

# --- hold --------------------------------------------------------------

fn test_world_hold() {
    test_group("world hold");
    var b = board_new(10, 20);
    var wd = world_new(b, 42);
    assert_eq(world_hold_type(wd), HOLD_EMPTY, "hold starts empty");
    assert_eq(world_hold_used(wd), 0, "hold unused at spawn");

    t_force(wd, 2, 0, 3, 5);                  # active = T
    var nextt = world_next(wd);              # the piece queued to come out
    assert_eq(world_hold(wd), 1, "first hold stashes and draws fresh");
    assert_eq(world_hold_type(wd), 2, "T is now held");
    assert_eq(world_cur_type(wd), nextt, "active is the drawn queue piece");
    assert_eq(world_hold_used(wd), 1, "hold marked used");

    # a second hold this drop is refused
    assert_eq(world_hold(wd), 0, "second hold this drop is a no-op");

    # after a swap, holding again exchanges active and held
    t_force(wd, 5, 0, 3, 5);                  # force active = J
    store64(wd + WO_HOLD_USED, 0);            # simulate a new drop
    assert_eq(world_hold(wd), 1, "swap with a non-empty hold");
    assert_eq(world_cur_type(wd), 2, "held T came out");
    assert_eq(world_hold_type(wd), 5, "J went into hold");

    # locking a piece re-arms hold
    var b2 = board_new(10, 20);
    var w2 = world_new(b2, 42);
    store64(w2 + WO_HOLD_USED, 1);
    t_force(w2, 1, 0, 3, 18);                 # O on the floor
    world_gravity(w2);                        # locks -> spawns
    assert_eq(world_hold_used(w2), 0, "hold re-armed after a lock");
    return 0;
}

# --- score -------------------------------------------------------------

fn test_score() {
    test_group("score");
    assert_eq(score_for_lines(0, 0), 0, "no lines, no points");
    assert_eq(score_for_lines(1, 0), 100, "single = 100");
    assert_eq(score_for_lines(2, 0), 300, "double = 300");
    assert_eq(score_for_lines(3, 0), 500, "triple = 500");
    assert_eq(score_for_lines(4, 0), 800, "tetris = 800");
    assert_eq(score_for_lines(1, 1), 200, "single x level 2");
    assert_eq(score_for_lines(4, 2), 2400, "tetris x level 3");
    assert_eq(level_for_lines(0), 0, "level 0 at 0 lines");
    assert_eq(level_for_lines(9), 0, "still level 0 at 9");
    assert_eq(level_for_lines(10), 1, "level 1 at 10");
    assert_eq(level_for_lines(25), 2, "level 2 at 25");

    # T-spin-aware base scoring (kind 0 regular, 1 mini, 2 proper)
    assert_eq(score_base(0, 2, 0), 300, "kind 0 falls back to the regular table");
    assert_eq(score_base(1, 0, 0), 100, "mini T-spin, no lines");
    assert_eq(score_base(1, 1, 0), 200, "mini T-spin single");
    assert_eq(score_base(2, 0, 0), 400, "proper T-spin, no lines");
    assert_eq(score_base(2, 1, 0), 800, "T-spin single");
    assert_eq(score_base(2, 2, 0), 1200, "T-spin double");
    assert_eq(score_base(2, 3, 1), 3200, "T-spin triple x level 2");

    # difficulty (back-to-back eligibility) + combo bonus
    assert_eq(is_difficult(0, 4), 1, "Tetris is difficult");
    assert_eq(is_difficult(0, 2), 0, "a plain double is not");
    assert_eq(is_difficult(2, 1), 1, "a line-clearing T-spin is difficult");
    assert_eq(is_difficult(1, 0), 0, "a no-line spin is not a difficult clear");
    assert_eq(combo_bonus(0, 0), 0, "first clear (combo 0) has no bonus");
    assert_eq(combo_bonus(1, 0), 50, "combo 1 = 50");
    assert_eq(combo_bonus(3, 1), 300, "combo 3 x level 2 = 300");
    return 0;
}

# --- scoring extensions: combo / back-to-back / T-spin ------------------

fn test_world_scoring() {
    test_group("world scoring");

    # combo: a clear while a chain is active adds the combo bonus
    var b = board_new(10, 20);
    t_fill_row_except(b, 19, 4, 5);
    var wd = world_new(b, 42);
    store64(wd + WO_SCORE, 0);
    store64(wd + WO_COMBO, 0);                # pretend one clear already happened
    t_force(wd, 1, 0, 3, 18);                 # O completes row 19
    assert_eq(world_gravity(wd), 1, "single clear");
    assert_eq(world_combo(wd), 1, "combo advanced to 1");
    assert_eq(world_score(wd), 150, "single (100) + combo-1 bonus (50)");

    # a clear-less lock breaks the combo
    var bb = board_new(10, 20);
    var wb = world_new(bb, 42);
    store64(wb + WO_COMBO, 3);
    t_force(wb, 1, 0, 3, 18);                 # O on the empty floor, no clear
    world_gravity(wb);
    assert_eq(world_combo(wb), 0 - 1, "clear-less lock resets combo");

    # back-to-back: a Tetris arms B2B; the next Tetris gets +50%
    var b2 = board_new(10, 20);
    t_fill_row_full(b2, 16); board_set(b2, 0, 16, 0);
    t_fill_row_full(b2, 17); board_set(b2, 0, 17, 0);
    t_fill_row_full(b2, 18); board_set(b2, 0, 18, 0);
    t_fill_row_full(b2, 19); board_set(b2, 0, 19, 0);
    var w2 = world_new(b2, 42);
    store64(w2 + WO_SCORE, 0);
    store64(w2 + WO_COMBO, 0 - 1);
    t_force(w2, 0, 1, 0 - 2, 16);             # vertical I fills col 0, rows 16..19
    assert_eq(world_gravity(w2), 4, "Tetris clears four");
    assert_eq(world_b2b(w2), 1, "Tetris arms back-to-back");
    assert_eq(world_score(w2), 800, "first Tetris is 800, no B2B bonus yet");

    var b3 = board_new(10, 20);
    t_fill_row_full(b3, 16); board_set(b3, 0, 16, 0);
    t_fill_row_full(b3, 17); board_set(b3, 0, 17, 0);
    t_fill_row_full(b3, 18); board_set(b3, 0, 18, 0);
    t_fill_row_full(b3, 19); board_set(b3, 0, 19, 0);
    var w3 = world_new(b3, 42);
    store64(w3 + WO_SCORE, 0);
    store64(w3 + WO_B2B, 1);                  # previous clear was difficult
    store64(w3 + WO_COMBO, 0 - 1);
    t_force(w3, 0, 1, 0 - 2, 16);
    assert_eq(world_gravity(w3), 4, "second Tetris clears four");
    assert_eq(world_score(w3), 1200, "back-to-back Tetris = 800 + 400");

    # T-spin double: a rotated T wedged into a 3-corner slot
    var b4 = board_new(10, 20);
    t_fill_row_full(b4, 18);
    board_set(b4, 3, 18, 0); board_set(b4, 4, 18, 0); board_set(b4, 5, 18, 0);
    t_fill_row_full(b4, 19);
    board_set(b4, 4, 19, 0);
    board_set(b4, 5, 17, 1);                  # overhang -> the third (back) corner
    var w4 = world_new(b4, 42);
    store64(w4 + WO_SCORE, 0);
    store64(w4 + WO_COMBO, 0 - 1);
    store64(w4 + WO_B2B, 0);
    t_force(w4, 2, 2, 3, 17);                 # T pointing down, body in the slot
    store64(w4 + WO_LAST_ROT, 1);             # as if it just rotated in
    store64(w4 + WO_LAST_KICK, 1);
    assert_eq(world_tspin_kind(w4), 2, "3-corner proper T-spin detected");
    assert_eq(world_gravity(w4), 2, "T-spin double clears two");
    assert_eq(world_last_tspin(w4), 2, "lock recorded as a proper T-spin");
    assert_eq(world_score(w4), 1200, "T-spin double scores 1200 at level 0");

    # a plain (non-rotated) T placed the same way is not a T-spin
    var b5 = board_new(10, 20);
    t_fill_row_full(b5, 18);
    board_set(b5, 3, 18, 0); board_set(b5, 4, 18, 0); board_set(b5, 5, 18, 0);
    t_fill_row_full(b5, 19);
    board_set(b5, 4, 19, 0);
    board_set(b5, 5, 17, 1);
    var w5 = world_new(b5, 42);
    t_force(w5, 2, 2, 3, 17);
    store64(w5 + WO_LAST_ROT, 0);             # arrived by a shift, not a rotation
    assert_eq(world_tspin_kind(w5), 0, "no T-spin without a preceding rotation");
    return 0;
}

# --- render ------------------------------------------------------------

fn test_render() {
    test_group("render");
    var f = fb_new(24, 24);
    assert_eq(fb_w(f), 24, "fb width");
    assert_eq(fb_h(f), 24, "fb height");
    fb_set(f, 2, 3, 10, 20, 30);
    assert_eq(fb_get(f, 2, 3, 0), 10, "pixel R");
    assert_eq(fb_get(f, 2, 3, 1), 20, "pixel G");
    assert_eq(fb_get(f, 2, 3, 2), 30, "pixel B");
    fb_fill_rect(f, 0, 0, 100, 100, 5, 5, 5);    # clips to surface, no overrun
    assert_eq(fb_get(f, 23, 23, 0), 5, "fill clipped to surface");

    assert_eq(rgb_r(type_rgb(0)), 40, "I colour R");
    assert_eq(rgb_g(type_rgb(0)), 180, "I colour G");
    assert_eq(rgb_b(type_rgb(0)), 200, "I colour B");

    # render a board with one locked I-cell at (0,0)
    var b = board_new(10, 20);
    board_set(b, 0, 0, 1);                        # value 1 -> type 0 (I)
    var wd = world_new(b, 42);
    var surf = fb_new(10 * CELL, 20 * CELL);
    render_world(surf, wd);
    assert_eq(fb_get(surf, 2, 2, 0), 40, "cell (0,0) drawn in I teal");
    assert_eq(fb_get(surf, 5, 230, 0), 12, "empty area shows background");

    # ghost: the landing shadow renders dim (quarter brightness) below the
    # active piece. Force an O near the top; its ghost lands on the floor.
    var b2 = board_new(10, 20);
    var w2 = world_new(b2, 42);
    t_force(w2, 1, 0, 3, 0);                       # O at the top
    assert_eq(world_ghost_y(w2), 18, "O ghost lands on the floor row");
    var surf2 = fb_new(10 * CELL, 20 * CELL);
    render_world(surf2, w2);
    # O cell (1,0) at ghost origin (3,18) -> board (4,18) -> px (49,217),
    # dim amber: R = 230/4 = 57. Active O is up at rows 0,1, far above.
    assert_eq(fb_get(surf2, (4 * CELL) + 1, (18 * CELL) + 1, 0), 57, "ghost cell drawn dim");
    assert_eq(fb_get(surf2, (4 * CELL) + 1, 1, 0), 230, "active O still full brightness");
    return 0;
}

# --- input -------------------------------------------------------------

fn test_input() {
    test_group("input");
    assert_eq(poly_key_action(97), ACT_LEFT, "a -> left");
    assert_eq(poly_key_action(100), ACT_RIGHT, "d -> right");
    assert_eq(poly_key_action(115), ACT_SOFT, "s -> soft drop");
    assert_eq(poly_key_action(32), ACT_HARD, "space -> hard drop");
    assert_eq(poly_key_action(119), ACT_ROT_CW, "w -> rotate CW");
    assert_eq(poly_key_action(122), ACT_ROT_CCW, "z -> rotate CCW");
    assert_eq(poly_key_action(99), ACT_HOLD, "c -> hold");
    assert_eq(poly_key_action(113), ACT_QUIT, "q -> quit");
    assert_eq(poly_key_action(120), 0, "unmapped key -> no action");
    return 0;
}

# --- gravity curve -----------------------------------------------------

fn test_gravity() {
    test_group("gravity");
    assert_eq(gravity_frames(0), 48, "level 0 = 48 frames/cell");
    assert_eq(gravity_frames(0 - 3), 48, "negative level clamps to 48");
    assert_eq(gravity_frames(9), 6, "level 9 = 6");
    assert_eq(gravity_frames(10), 5, "level 10 = 5");
    assert_eq(gravity_frames(12), 5, "level 12 = 5 (band)");
    assert_eq(gravity_frames(13), 4, "level 13 = 4");
    assert_eq(gravity_frames(19), 2, "level 19 = 2");
    assert_eq(gravity_frames(28), 2, "level 28 = 2 (band)");
    assert_eq(gravity_frames(29), 1, "level 29 = 1 (kill speed)");
    assert_eq(gravity_frames(99), 1, "stays at 1 past 29");
    # monotonic non-increasing across the table
    var l = 1;
    var ok = 1;
    while (l < 40) {
        if (gravity_frames(l) > gravity_frames(l - 1)) { ok = 0; }
        l = l + 1;
    }
    assert_eq(ok, 1, "gravity curve never speeds back up");
    return 0;
}

# --- world tick (gravity timing + lock delay + soft drop) --------------

fn test_world_tick() {
    test_group("world tick");
    var b = board_new(10, 20);
    var wd = world_new(b, 42);

    # airborne at level 0: 47 ticks hold, the 48th drops one cell
    t_force(wd, 1, 0, 3, 0);
    var i = 0;
    while (i < 47) { world_tick(wd, 0); i = i + 1; }
    assert_eq(world_cur_y(wd), 0, "no drop before the gravity interval");
    world_tick(wd, 0);
    assert_eq(world_cur_y(wd), 1, "drops one cell at the interval");

    # grounded: lock delay holds for LOCK_DELAY_FRAMES, then commits
    var b2 = board_new(10, 20);
    var w2 = world_new(b2, 42);
    t_force(w2, 1, 0, 3, 18);                # O resting on the floor
    assert_eq(world_grounded(w2), 1, "piece on the floor is grounded");
    i = 0;
    while (i < 29) { world_tick(w2, 0); i = i + 1; }
    assert_eq(board_count(world_board(w2)), 0, "not locked during the grace window");
    world_tick(w2, 0);
    assert_eq(board_count(world_board(w2)), 4, "locks after the lock delay");

    # lock-delay reset: a move while grounded restarts the timer
    var b3 = board_new(10, 20);
    var w3 = world_new(b3, 42);
    t_force(w3, 1, 0, 3, 18);
    i = 0;
    while (i < 29) { world_tick(w3, 0); i = i + 1; }
    assert_eq(world_move(w3, 1), 1, "slide right while grounded");
    assert_eq(board_count(world_board(w3)), 0, "move reset the lock timer");
    i = 0;
    while (i < 29) { world_tick(w3, 0); i = i + 1; }
    assert_eq(board_count(world_board(w3)), 0, "still resting after the reset");
    world_tick(w3, 0);
    assert_eq(board_count(world_board(w3)), 4, "locks once the reset window elapses");

    # soft drop: tightens the cadence to SOFT_DROP_FRAMES and scores a point
    var b4 = board_new(10, 20);
    var w4 = world_new(b4, 42);
    t_force(w4, 1, 0, 3, 0);
    var s0 = world_score(w4);
    world_tick(w4, 1);
    assert_eq(world_cur_y(w4), 0, "soft: no drop on frame 1 of 2");
    world_tick(w4, 1);
    assert_eq(world_cur_y(w4), 1, "soft: drops on frame 2");
    assert_eq(world_score(w4), s0 + 1, "soft drop scores one point per cell");
    return 0;
}

# --- DAS ---------------------------------------------------------------

fn test_das() {
    test_group("das");
    var d = das_new();
    assert_eq(das_update(d, 1), 1, "fresh press shifts once");
    var i = 0;
    var any = 0;
    while (i < 15) {
        if (das_update(d, 1) != 0) { any = 1; }
        i = i + 1;
    }
    assert_eq(any, 0, "no shift while charging the initial delay");
    assert_eq(das_update(d, 1), 1, "auto-shift fires at DAS_DELAY");
    assert_eq(das_update(d, 1), 0, "quiet between auto-repeats");

    assert_eq(das_update(d, 0), 0, "release emits nothing");
    assert_eq(das_update(d, 1), 1, "re-press shifts immediately (timer was reset)");
    assert_eq(das_update(d, 0 - 1), 0 - 1, "direction change shifts immediately");
    return 0;
}

# --- HUD ---------------------------------------------------------------

fn test_hud() {
    test_group("hud");
    hud_init();
    var f = fb_new(64, 32);
    fb_clear(f, 0, 0, 0);
    # digit 8 = glyph(7,5,7,5,7): top row all-on, row1 middle column off
    hud_draw_digit(f, 0, 0, 8, 2, 100, 150, 200);
    assert_eq(fb_get(f, 0, 0, 0), 100, "digit 8 top-left pixel set");
    assert_eq(fb_get(f, 0, 0, 1), 150, "digit 8 top-left pixel G");
    assert_eq(fb_get(f, 2, 2, 0), 0, "digit 8 row1 middle column is a gap");

    # number 0 renders the '0' glyph (row0 all-on) at the origin
    fb_clear(f, 0, 0, 0);
    hud_draw_number(f, 0, 0, 0, 1, 200, 10, 10);
    assert_eq(fb_get(f, 0, 0, 0), 200, "number 0 draws a digit");

    # next-piece preview: force the next piece to O and check a known cell
    var b = board_new(10, 20);
    var wd = world_new(b, 42);
    store8(load64(wd + WO_BAG), 1);           # O at the queue front — cells (1,0)(2,0)(1,1)(2,1)
    fb_clear(f, 0, 0, 0);
    hud_draw_preview(f, wd, 0, 0, 6);
    assert_eq(fb_get(f, 6, 0, 0), 230, "preview O cell (1,0) in O amber");
    assert_eq(fb_get(f, 0, 0, 0), 0, "preview cell (0,0) empty for O");

    # multi-piece NEXT queue: force the first two upcoming pieces and check
    # the second renders a row below the first. Queue front O, then I.
    store8(load64(wd + WO_BAG), 1);           # peek 0 = O
    store8(load64(wd + WO_BAG) + 1, 0);       # peek 1 = I
    fb_clear(f, 0, 0, 0);
    hud_draw_next_queue(f, wd, 0, 0, 6, 3);
    assert_eq(fb_get(f, 6, 0, 0), 230, "queue piece 0 (O) at the top in amber");
    # I (peek 1) sits at row offset (6*3+4)=22; its cells are on row 1 -> +6.
    assert_eq(fb_get(f, 0, 28, 0), 40, "queue piece 1 (I) drawn a row down in teal");

    # full HUD panel render lands to the right of the well. The surface
    # width must use explicit parens around the multiply (Cyrius mis-parses
    # `literal * ENUM + literal` — see hud_panel_x / CLAUDE.md).
    var surf = fb_new((10 * CELL) + 90, 20 * CELL);
    assert_eq(fb_w(surf), 210, "panel surface is well + 90px HUD wide");
    assert_eq(hud_panel_x(wd), 126, "HUD panel x is just right of the well");
    fb_clear(surf, 0, 0, 0);
    store64(wd + WO_HOLD, 4);                 # Z in the hold slot (rose, R=220)
    hud_render(surf, wd);
    assert_eq(fb_get(surf, hud_panel_x(wd), 16, 0), 240, "score digit drawn in the side panel");
    # Z cell (0,0) at the HOLD slot origin (panel_x, 190) renders in rose.
    assert_eq(fb_get(surf, hud_panel_x(wd), 190, 0), 220, "held Z piece drawn in the HOLD slot");
    return 0;
}

fn main() {
    alloc_init();
    test_piece();
    test_board();
    test_rng();
    test_world_new();
    test_world_move();
    test_world_rotate();
    test_srs();
    test_world_gravity();
    test_world_clear();
    test_world_topout();
    test_world_harddrop();
    test_world_hold();
    test_world_tick();
    test_gravity();
    test_das();
    test_score();
    test_world_scoring();
    test_render();
    test_hud();
    test_input();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
